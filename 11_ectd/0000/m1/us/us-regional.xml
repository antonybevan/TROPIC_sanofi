<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="../../util/style/us-regional.xsl"?>
<!DOCTYPE fda-regional:fda-regional SYSTEM "../../util/dtd/us-regional-v3-3.dtd">
<fda-regional:fda-regional xmlns:fda-regional="http://www.ich.org/fda"
                           xmlns:xlink="http://www.w3c.org/1999/xlink"
                           xml:lang="en" dtd-version="3.3">
  <admin>
    <!-- EXAMPLE / DEMONSTRATION metadata - this is NOT a real FDA submission.
         "000000" is a placeholder, not an FDA-assigned number. Replace every
         applicant + application identifier with the real FDA-assigned values
         before any gateway submission. -->
    <applicant-info>
      <id>EXAMPLE</id>
      <company-name>TROPIC Re-Analysis (student demonstration)</company-name>
      <applicant-contacts>
        <applicant-contact>
          <applicant-contact-name applicant-contact-type="regulatory">Example Contact</applicant-contact-name>
          <telephones>
            <telephone telephone-number-type="work">000-000-0000</telephone>
          </telephones>
          <emails>
            <email>example@example.org</email>
          </emails>
        </applicant-contact>
      </applicant-contacts>
    </applicant-info>
    <application-set>
      <application application-containing-files="true">
        <application-information>
          <application-number application-type="NDA">000000</application-number>
        </application-information>
        <submission-information>
          <submission-id submission-type="original-application">0000</submission-id>
          <sequence-number submission-sub-type="original">0000</sequence-number>
        </submission-information>
      </application>
    </application-set>
  </admin>
</fda-regional:fda-regional>
