# ==============================================================================
# TROPIC-CDI-E2E-v2.0 eCTD Pipeline Gitignore Rules
# ==============================================================================

# Clinical Data Protection (MANDATORY: Never commit patient data)
01_raw_source/
AllProvidedFiles_79.zip

# Binary Outputs & Artifacts (MANDATORY: Never commit binary XPT outputs)
04_adam/*.xpt
04_adam/*.sas7bdat
09_tfl/output/

# Telemetry and Health Audits
06_telemetry/pipeline_health.json
06_telemetry/health_dashboard.md
06_telemetry/p21_report.json
06_telemetry/reconciliation_report.html

# Logs & Temporary Files
backup_adam/
*.log
*.lst
*.pdf
*.rtf
*.png
.Rhistory
.RData
.Ruserdata
.Rprofile

# renv specific (except renv.lock which must be committed)
.Rproj.user/
renv/library/
renv/local/
renv/sandbox/
renv/staging/

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
.venv/
env/
venv/

# Node.js specific
node_modules/

# SAS Connection & Credentials Profiles
sascfg_personal.py
_authinfo
.authinfo

# Local IDE and temporary exploration folders
.claude/
scratch/
06_telemetry/reconciliation_status.json

# Generated from study_config.yaml by 06_telemetry/generate_config.py (do not edit/commit)
02_production_sas/00_config_generated.sas
06_telemetry/oda_status.json
06_telemetry/.oda_singleflight.lock
06_telemetry/.oda_session.json

# --- Roadmap #6: surface portfolio deliverables + honest execution evidence on GitHub ---
# Re-include the rendered TFL gallery (figures + text tables) and the pipeline-health /
# reconciliation evidence so a reviewer browsing the repo sees them without a local run.
# pipeline_health.json is committed as-is and transparently shows the current
# sas_execution_mode (e.g. "sim" until a real oda/local run is recorded). Negations must
# follow the broad *.png / output-dir ignores above; the directory is re-included first so
# its contents can be re-included.
!09_tfl/output/
!09_tfl/output/**
!06_telemetry/pipeline_health.json
!06_telemetry/reconciliation_status.json
