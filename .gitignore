# ==============================================================================
# TROPIC-CDI-E2E-v2.0 eCTD Pipeline Gitignore Rules
# ==============================================================================

# Clinical Data Protection (MANDATORY: Never commit patient data)
# Ignore the CONTENTS of 01_raw_source/ (note the /*, not /) so that the
# negations below can re-include specific non-patient files. A bare
# `01_raw_source/` prunes the whole dir and git never evaluates the `!` rules.
01_raw_source/*
AllProvidedFiles_79.zip

# Re-include reconstruction CODE, the validation report, and PUBLISHED aggregate
# data (no patient data): (a) code that generates the synthetic CbzP arm, and
# (b) digitised coordinates from the published de Bono 2010 Lancet figures.
# This also addresses Finding D (untracked reconstruction dependency).
!01_raw_source/reconstruct_cbzp_arm.R
!01_raw_source/reconstruct_cbzp_guyot.R
!01_raw_source/guyot_validation_report.R
!01_raw_source/guyot_validation_report.md
!01_raw_source/export_cbzp_xpt.R
!01_raw_source/guyot_digitised/
!01_raw_source/guyot_digitised/**

# Binary Outputs & Artifacts (MANDATORY: Never commit binary XPT outputs)
04_adam/*.xpt
04_adam/*.sas7bdat
04_adam/*.csv
09_tfl/output/

# Telemetry and Health Audits
06_telemetry/pipeline_health.json
06_telemetry/health_dashboard.md
06_telemetry/p21_report.json
06_telemetry/reconciliation_report.html

# Logs & Temporary Files
backup_adam/
*.log
*.lst
*.pdf
*.rtf
*.png
.Rhistory
.RData
.Ruserdata
.Rprofile

# renv specific (except renv.lock which must be committed)
.Rproj.user/
renv/library/
renv/local/
renv/sandbox/
renv/staging/

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
.venv/
env/
venv/

# Node.js specific
node_modules/

# CDISC CORE conformance engine + isolated venv (large, re-downloadable per P21_RUNBOOK; never commit)
.core_engine/
.core_venv/
# Pinnacle 21 Community + Java 8 runtime (large, re-downloadable per p21_adam_runrecord.md; never commit)
.p21/
06_telemetry/p21_out/
# Staged domain-named ADaM XPT copies fed to the conformance engine (patient-derived — never commit)
06_telemetry/_p21_datasets/
# CORE conformance engine output (may reference dataset paths)
06_telemetry/p21_report.*
# Regenerable define.xml metadata flattening (intermediate for the ADaM conformance gate)
06_telemetry/adam_conf_define_meta.json

# SAS Connection & Credentials Profiles
sascfg_personal.py
_authinfo
.authinfo

# Local IDE and temporary exploration folders
.claude/
scratch/
06_telemetry/reconciliation_status.json

# Generated from study_config.yaml by 06_telemetry/generate_config.py (do not edit/commit)
02_production_sas/00_config_generated.sas
06_telemetry/oda_status.json
06_telemetry/.oda_singleflight.lock
06_telemetry/.oda_session.json

# --- Roadmap #6: surface portfolio deliverables + honest execution evidence on GitHub ---
# Re-include the rendered TFL gallery (figures + text tables) and the pipeline-health /
# reconciliation evidence so a reviewer browsing the repo sees them without a local run.
# pipeline_health.json is committed as-is and transparently shows the current
# sas_execution_mode (e.g. "sim" until a real oda/local run is recorded). Negations must
# follow the broad *.png / output-dir ignores above; the directory is re-included first so
# its contents can be re-included.
!09_tfl/output/
!09_tfl/output/**
!06_telemetry/pipeline_health.json
!06_telemetry/reconciliation_status.json

# eCTD Module 5 package. The DATA-FREE preview (package_ectd.py --preview) is tracked for
# portfolio visibility; patient-level transport/native data is NEVER tracked, even when the
# full package is built locally with the licensed source data present.
m5/**/*.xpt
m5/**/*.sas7bdat
# Re-include the rendered submission artifacts that the global *.pdf / *.png rules would ignore.
!m5/**/*.pdf
!m5/**/*.png

.core_venv/

# Ephemeral CDISC CORE run inputs (contain patient-data XPT)
.core_run/

# macOS
.DS_Store
